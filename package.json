{
	"name": "@roster/repo",
	"version": "0.0.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/jkoczeniak/roster"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.2",
		"sherif": "^1.10.0",
		"turbo": "^2.8.7"
	},
	"description": "Roster — a local-first macOS desktop app for running a roster of persistent coding agents (Claude Code + Codex) in Ghostty-powered terminals",
	"license": "SEE LICENSE IN LICENSE.md",
	"packageManager": "bun@1.3.6",
	"private": true,
	"scripts": {
		"dev": "turbo run dev --filter=@roster/desktop",
		"build": "turbo build --filter=@roster/desktop",
		"test": "turbo test",
		"lint": "./scripts/lint.sh",
		"lint:fix": "biome migrate --write && biome check --write --unsafe .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"typecheck": "turbo typecheck",
		"ui-add": "turbo run ui-add",
		"postinstall": "./scripts/postinstall.sh",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo clean",
		"release:desktop": "./apps/desktop/create-release.sh",
		"db:generate:desktop": "bun run --cwd packages/local-db generate"
	},
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*",
		"tooling/*"
	]
}
